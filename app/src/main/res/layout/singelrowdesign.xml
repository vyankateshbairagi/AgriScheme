<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardElevation="10dp"
    app:cardCornerRadius="15dp"
    android:layout_margin="10dp"
   >

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#fff"
        android:padding="7dp"
        >

        <TextView
            android:id="@+id/name1"
            android:layout_width="140dp"
            android:layout_height="wrap_content"
            android:layout_marginLeft="10dp"
            android:layout_marginTop="10dp"
            android:text="   Name:"
            android:drawableLeft="@drawable/ic_baseline_person_24"
            android:textStyle="bold"
            android:textColor="#07480E"
            android:textSize="15dp" />
        <TextView
            android:id="@+id/textname"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_toRightOf="@+id/name1"
            android:text=" "
            android:layout_marginLeft="5dp"
            android:textColor="#07480E"
            android:textSize="15dp" />

        <TextView
            android:id="@+id/address"
            android:layout_width="140dp"
            android:layout_height="wrap_content"
            android:layout_below="@id/textname"
            android:layout_marginLeft="10dp"
            android:layout_marginTop="10dp"
            android:drawableLeft="@drawable/ic_baseline_home_24"
            android:text="   Address: "
            android:textColor="#07480E"
            android:textSize="15dp"
            android:textStyle="bold" />
        <TextView
            android:id="@+id/textaddress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/textname"
            android:layout_marginTop="10dp"
            android:textColor="#07480E"
            android:layout_toRightOf="@+id/address"
            android:text=" "
            android:layout_marginLeft="5dp"
            android:textSize="15dp" />

        <TextView
            android:id="@+id/phone"
            android:layout_width="140dp"
            android:layout_height="wrap_content"
            android:layout_below="@id/textaddress"
            android:layout_marginLeft="10dp"
            android:layout_marginTop="10dp"
            android:drawableLeft="@drawable/ic_baseline_call_24"
            android:text="   Contact no: "
            android:textColor="#07480E"
            android:textSize="15dp"
            android:textStyle="bold" />
        <TextView
            android:id="@+id/textphone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/textaddress"
            android:layout_marginTop="10dp"
            android:layout_toRightOf="@+id/phone"
            android:text=" "
            android:layout_marginLeft="5dp"
            android:textColor="#07480E"
            android:textSize="15dp"/>

        <TextView
            android:id="@+id/header1"
            android:layout_width="140dp"
            android:layout_height="wrap_content"
            android:layout_below="@id/textphone"
            android:layout_marginLeft="10dp"
            android:layout_marginTop="10dp"
            android:drawableLeft="@drawable/ic_baseline_file_upload_24"
            android:text="   Adhar No:"
            android:textColor="#07480E"
            android:textSize="15dp"
            android:textStyle="bold" />
        <TextView
            android:id="@+id/header"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textColor="#07480E"
            android:textSize="15dp"
            android:layout_marginLeft="5dp"
            android:layout_below="@id/textphone"
            android:layout_toRightOf="@+id/header1"
            android:text=" " />

        <ImageView
            android:id="@+id/img1"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_below="@id/textphone"
            android:layout_marginLeft="10dp"
            android:layout_marginTop="10dp"
            android:layout_toRightOf="@+id/header"
            app:srcCompat="@drawable/ic_baseline_picture_as_pdf_24" />

        <TextView
            android:id="@+id/pan"
            android:layout_width="140dp"
            android:layout_height="wrap_content"
            android:layout_below="@id/header1"
            android:layout_marginLeft="10dp"
            android:layout_marginTop="10dp"
            android:drawableLeft="@drawable/ic_baseline_file_upload_24"
            android:text="   Pan No:"
            android:textColor="#07480E"
            android:textSize="15dp"
            android:textStyle="bold" />
        <TextView
            android:id="@+id/textpan"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textColor="#07480E"
            android:textSize="15dp"
            android:layout_marginLeft="5dp"
            android:layout_toRightOf="@+id/pan"
            android:layout_below="@id/header1"
            android:text=" " />

        <ImageView
            android:id="@+id/imgpan"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_below="@id/header"
            android:layout_marginLeft="10dp"
            android:layout_marginTop="10dp"
            android:layout_toRightOf="@+id/textpan"
            app:srcCompat="@drawable/ic_baseline_picture_as_pdf_24" />

        <TextView
            android:id="@+id/uatara"
            android:layout_width="140dp"
            android:layout_height="wrap_content"
            android:layout_below="@id/textpan"
            android:layout_marginLeft="10dp"
            android:layout_marginTop="10dp"
            android:drawableLeft="@drawable/ic_baseline_file_upload_24"
            android:text="   7-12Utara no:"
            android:textColor="#07480E"
            android:textSize="15dp"
            android:textStyle="bold" />
        <TextView
            android:id="@+id/textuatara"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textColor="#07480E"
            android:textSize="15dp"
            android:layout_marginLeft="5dp"
            android:layout_toRightOf="@+id/uatara"
            android:layout_below="@id/pan"
            android:text=" " />

        <ImageView
            android:id="@+id/imguatara"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_below="@id/pan"
            android:layout_marginLeft="10dp"
            android:layout_marginTop="1dp"
            android:layout_toRightOf="@+id/textuatara"
            app:srcCompat="@drawable/ic_baseline_picture_as_pdf_24" />
    </RelativeLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">


    <ImageButton
            android:id="@+id/imgapp"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_marginTop="20dp"
              android:layout_marginLeft="300dp"
            android:background="@drawable/ic_baseline_check_circle_24"
             tools:ignore="NotSibling" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <ImageButton
            android:id="@+id/imgreject"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_marginLeft="340dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/ic_baseline_delete_24" />
    </LinearLayout>


</androidx.cardview.widget.CardView>
